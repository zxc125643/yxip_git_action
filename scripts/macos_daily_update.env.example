# Copy this file to scripts/macos_daily_update.env and edit values for this Mac.

# Cloudflare hostname used by scripts/local_cf_trace.py.
TRACE_HOST=edgar.vegaavc.cn

# Worker project path. Required only when DEPLOY_WORKER=true or RUN_SOCKS5=true.
EDGAR_DIR=$HOME/projects/edgar3.0

# Keep these false until the Worker project and wrangler auth are available on this Mac.
DEPLOY_WORKER=false
RUN_SOCKS5=false

# Daily update behavior.
TRACE_INPUT=ip_clean.txt
TRACE_WORKERS=16
TRACE_TIMEOUT=8
TOP_N=5
MIN_PURITY=80
PULL_REPO=true
PUSH_TRACE=false

# Optional: use your own SOCKS5 secret without putting it directly in launchd.
# CUSTOM_SOCKS5_FILE=$HOME/projects/edgar3.0/custom_socks5.txt
